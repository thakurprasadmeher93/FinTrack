# ======================================================
# FinTrack - Environment Variables Configuration
# Copy this file to .env and fill in your values
# ======================================================

# Node Environment (keep as 'production' on server)
NODE_ENV=production

# Server Port (Hostinger usually assigns a port, check hPanel)
PORT=3000

# PostgreSQL Database URL
# Format: postgresql://username:password@hostname:port/database_name
# On Hostinger: create a database in hPanel > Databases > MySQL/PostgreSQL
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/fintrack_db

# Session Secret Key (use a long random string - minimum 32 characters)
# Generate one at: https://generate-secret.vercel.app/64
SESSION_SECRET=your-very-long-random-secret-key-here-change-this

# Replit Auth (only needed if using Replit OAuth - can leave blank on Hostinger)
REPL_ID=
ISSUER_URL=
